// Prisma schema - PostgreSQL
// Run `npm run db:push` after setting DATABASE_URL in .env to create these tables.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

model Application {
  id              String            @id @default(uuid())
  firstName       String
  surname         String
  dateOfBirth     DateTime
  clan            String
  address         String
  gender          String
  email           String
  photoUrl        String?
  idNumber        String            @unique // e.g. "RC 942183" - generated at submission
  verificationCode String           @unique // 15-char hex OTP - generated at submission
  status          ApplicationStatus @default(PENDING)

  // Assigned only on approval - the incrementing unique certificate number
  certificateNumber Int?            @unique // sequential integer, e.g. 2006241
  certificateSerial  String?        @unique // formatted, e.g. "LS/ZA 2006241"

  issuedOn        DateTime?
  reviewedBy      String?
  reviewedAt      DateTime?
  rejectionReason String?

  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
}

// Keeps track of the last issued certificate number so it always increments safely.
model CertificateCounter {
  id           Int @id @default(1)
  lastNumber   Int @default(2006240) // next issued will be 2006241 to match your sample
}

model Admin {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  role         String   @default("ADMIN") // ADMIN | COORDINATING_CHIEF | SENIOR_CHIEF
  createdAt    DateTime @default(now())
}
